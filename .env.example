# Cópia este arquivo para .env e ajuste os valores conforme o ambiente.
# Estes são os mesmos defaults usados quando a variável não está definida.

# Servidor HTTP
PORT=8000

# Banco de dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=1234
DB_NAME=postgres
DB_SSLMODE=disable
